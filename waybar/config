{
  "layer": "top",
  "position": "top",
  "height": 34,
  "spacing": 0,

  "modules-left": [
    "custom/ws1",
    "custom/ws2",
    "custom/ws3",
    "custom/ws4",
    "custom/ws5",
    "hyprland/language",
    "hyprland/window"
  ],

  "modules-center": [
    "clock",
    "mpris"
  ],

  "modules-right": [
    "wireplumber",
    "custom/weather",
    "custom/gpu",
    "cpu",
    "memory",
    "tray",
    "disk",
    "network",
    "idle_inhibitor",
    "custom/reload",
    "custom/power"
  ],

  "custom/ws1": {
    "exec": "$HOME/.config/waybar/scripts/ws.sh 1",
    "return-type": "json",
    "signal": 8,
    "format": "{}",
    "on-click": "hyprctl eval 'hl.dispatch(hl.dsp.focus({ workspace = \"1\" }))'; pkill -RTMIN+8 waybar"
  },

  "custom/ws2": {
    "exec": "$HOME/.config/waybar/scripts/ws.sh 2",
    "return-type": "json",
    "signal": 8,
    "format": "{}",
    "on-click": "hyprctl eval 'hl.dispatch(hl.dsp.focus({ workspace = \"2\" }))'; pkill -RTMIN+8 waybar"
  },

  "custom/ws3": {
    "exec": "$HOME/.config/waybar/scripts/ws.sh 3",
    "return-type": "json",
    "signal": 8,
    "format": "{}",
    "on-click": "hyprctl eval 'hl.dispatch(hl.dsp.focus({ workspace = \"3\" }))'; pkill -RTMIN+8 waybar"
  },

  "custom/ws4": {
    "exec": "$HOME/.config/waybar/scripts/ws.sh 4",
    "return-type": "json",
    "signal": 8,
    "format": "{}",
    "on-click": "hyprctl eval 'hl.dispatch(hl.dsp.focus({ workspace = \"4\" }))'; pkill -RTMIN+8 waybar"
  },

  "custom/ws5": {
    "exec": "$HOME/.config/waybar/scripts/ws.sh 5",
    "return-type": "json",
    "signal": 8,
    "format": "{}",
    "on-click": "hyprctl eval 'hl.dispatch(hl.dsp.focus({ workspace = \"5\" }))'; pkill -RTMIN+8 waybar"
  },

  "hyprland/window": {
    "format": "{}",
    "max-length": 45
  },

  "hyprland/language": {
    "format": "’ä£  {}"
  },

  "clock": {
    "format": "’ĆŚ  {:%H:%M}",
    "format-alt": "’ü│  {:%d.%m.%Y  %H:%M:%S}"
  },

  "cpu": {
    "format": "’ŗø  {usage}%",
    "interval": 2
  },

  "memory": {
    "format": "Ņ┐ģ  {}%",
    "interval": 2
  },

  "tray": {
    "icon-size": 18,
    "spacing": 10
  },

  "custom/gpu": {
    "exec": "$HOME/.config/waybar/scripts/gpu.sh",
    "format": "{}",
    "interval": 2,
    "tooltip": false
  },

  "custom/weather": {
    "exec": "$HOME/.config/waybar/scripts/weather.sh",
    "format": "{}",
    "interval": 900,
    "return-type": "json",
    "tooltip": false
  },

  "custom/power": {
    "format": "’Ćæ",
    "tooltip": false,
    "on-click": "$HOME/.config/hypr/scripts/powermenu.sh"
  },

  "disk": {
    "path": "/",
    "format": "¾░ŗŖ  {percentage_used}%"
  },

  "network": {
    "format-ethernet": "¾░łĆ  {ifname} {ipaddr}",
    "format-wifi": "’ć½  {essid} {signalStrength}%",
    "format-disconnected": "¾░¢¬ offline",
    "tooltip-format": "{ifname}\nIP: {ipaddr}\nGW: {gwaddr}\nUp: {bandwidthUpBits}\nDown: {bandwidthDownBits}",
    "interval": 1,
    "on-click": "kitty --hold -e nmtui"
  },

  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": 18,
    "on-click": "activate",
    "on-click-middle": "close"
  },

  "mpris": {
    "format": "’Ćü  {player_icon} {title}",
    "format-paused": "’üī  {title}",
    "max-length": 35,
    "player-icons": {
      "default": "Ō¢Č",
      "firefox": "’ē®",
      "chromium": "’ē©",
      "spotify": "’å╝"
    },
    "on-click": "playerctl play-pause",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous"
  },

  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "’ü«",
      "deactivated": "’ü░"
    },
    "tooltip": false
  },

  "wireplumber": {
    "format": "’Ć©  {volume}%",
    "format-muted": "¾░Ø¤ muted",
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+",
    "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-",
    "max-volume": 150,
    "tooltip": false
  },

  "custom/reload": {
    "format": "¾░æō",
    "tooltip": false,
    "on-click": "sh -c 'pkill waybar; setsid waybar >/dev/null 2>&1 &'"
  }
}
